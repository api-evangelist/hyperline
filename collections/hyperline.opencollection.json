    {
      "info": { "name": "Billable Events", "type": "folder" },
      "items": [
        {
          "info": { "name": "Ingest billable events", "type": "http" },
          "http": {
            "method": "POST",
            "url": "https://api.hyperline.co/v1/billable-events",
            "body": { "type": "json", "data": "{}" }
          },
          "docs": "Ingest one or more billable events."
        },
        {
          "info": { "name": "Simulate prices for billable events", "type": "http" },
          "http": {
            "method": "POST",
            "url": "https://api.hyperline.co/v1/billable-events/simulate-prices",
            "body": { "type": "json", "data": "{}" }
          },
          "docs": "Simulate prices for billable events."
        }
      ]
    },
    {
      "info": { "name": "Invoices", "type": "folder" },
      "items": [
        {
          "info": { "name": "List invoices", "type": "http" },
          "http": {
